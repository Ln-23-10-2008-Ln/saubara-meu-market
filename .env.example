# ─── Turso ───────────────────────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Auth ────────────────────────────────────────────────────────────────────
SESSION_SECRET=your-long-random-secret-here
PEPPER=your-pepper-secret-here
HMAC_SECRET=your-hmac-secret-here

# ─── Email ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
# Set to your verified Resend domain (e.g. saubarameumarket.com.br)
# Health check returns emailConfigured=true only when both this AND RESEND_API_KEY are set
RESEND_FROM_DOMAIN=saubarameumarket.com.br

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@saubara.com
ADMIN_PASSWORD=admin2024

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
